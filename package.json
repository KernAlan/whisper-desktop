{
  "name": "whisper-desktop",
  "version": "1.1.0",
  "description": "A universal voice keyboard for inserting clean speech-to-text into any desktop interface.",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "electron .",
    "start": "node cli.js",
    "build": "electron-builder",
    "test": "node --test test/*.test.js",
    "check": "node scripts/check-syntax.js"
  },
  "keywords": [
    "dictation",
    "speech-to-text",
    "voice-input"
  ],
  "author": "Alan Kern",
  "license": "Apache-2.0",
  "build": {
    "appId": "com.kernalan.whisperdesktop",
    "productName": "Whisper Desktop",
    "asar": true,
    "files": [
      "src/**/*",
      "!src/main/assets/wake/**/*",
      "index.html",
      "settings.html",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/main/assets/wake",
        "to": "wake"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "linux": {
      "category": "Utility",
      "target": "AppImage"
    }
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "fs-extra": "^11.3.6",
    "groq-sdk": "^1.3.0",
    "sherpa-onnx-node": "^1.13.4"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  }
}
